# RENDERED sysctl profile for {{ node.hostname }}. Applied with: sysctl -p
# Each knob is chosen for LOW LATENCY, sometimes at the cost of throughput.

# Let the socket layer busy-poll for {{ node.pillar.busy_poll_us }}us before
# yielding, trading CPU for lower wakeup latency on incoming ticks.
net.core.busy_poll = {{ node.pillar.busy_poll_us }}
net.core.busy_read = {{ node.pillar.busy_poll_us }}

# Bigger socket buffers so a burst of ticks doesn't drop under load.
net.core.rmem_max = 16777216
net.core.wmem_max = 16777216

# Disable TCP slow-start-after-idle so a quiet connection doesn't re-slow-start
# on the next tick (a classic surprise latency spike after a lull).
net.ipv4.tcp_slow_start_after_idle = 0
